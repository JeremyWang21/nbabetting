# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nbabetting:nbabetting@postgres:5432/nbabetting
POSTGRES_DB=nbabetting
POSTGRES_USER=nbabetting
POSTGRES_PASSWORD=nbabetting

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── API Keys ──────────────────────────────────────────────────────────────────
# Sign up at https://the-odds-api.com
ODDS_API_KEY=your_odds_api_key_here

# Sign up at https://rapidapi.com/tank01/api/tank01-fantasy-stats
TANK01_API_KEY=your_tank01_rapidapi_key_here

# ─── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=INFO

# ─── Scheduler ─────────────────────────────────────────────────────────────────
# How often to poll The Odds API for live prop lines (seconds)
ODDS_POLL_INTERVAL_SECONDS=180
